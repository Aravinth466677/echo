PORT=5000
NODE_ENV=development

# Frontend Origin
CLIENT_URL=https://echo-ashy-chi.vercel.app

# Database Configuration
# Use Render PostgreSQL in production.
DATABASE_URL=postgres://<render-user>:<render-password>@<render-host>:5432/<render-database>
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echo_db
DB_USER=postgres
DB_PASSWORD=yaanai12345
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT Secret (change in production)
JWT_SECRET=your_jwt_secret_key_change_in_production

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Aggregation Settings
DEFAULT_AGGREGATION_RADIUS=100
DEFAULT_TIME_WINDOW_HOURS=72
